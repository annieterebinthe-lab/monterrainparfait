---
const currentYear = new Date().getFullYear();

const services = [
  {
    label: "Débroussaillage",
    href: "/services/debroussaillage",
  },
  {
    label: "Taille de haies",
    href: "/services/taille-haies",
  },
  {
    label: "Entretien de jardin",
    href: "/services/entretien-jardin",
  },
  {
    label: "Nettoyage de terrain",
    href: "/services/nettoyage-terrain",
  },
];

const serviceAreas = [
  "Luzech",
  "Cahors",
  "Pradines",
  "Mercuès",
  "Douelle",
  "Caillac",
  "Espère",
  "Puy-l’Évêque",
];

const whatsappLink =
  "https://wa.me/33743528759?text=Bonjour%2C%20je%20souhaite%20obtenir%20un%20devis%20gratuit%20pour%20mon%20terrain.";
---

<footer class="bg-[#062f24] text-white">
  <!-- Partie principale -->
  <div class="mx-auto max-w-7xl px-6 py-16 lg:py-20">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-12">
      <!-- Marque -->
      <div class="lg:col-span-4">
        <a href="/" class="inline-flex flex-col">
          <span class="text-3xl font-black tracking-tight">
            Mon Terrain Parfait
          </span>

          <span
            class="mt-2 text-xs font-bold uppercase tracking-[0.32em] text-green-300"
          >
            Débroussaillage • Entretien
          </span>
        </a>

        <p class="mt-6 max-w-xl leading-7 text-green-50/75">
          Entretien d’espaces verts, débroussaillage, taille de haies et
          nettoyage de terrain à Luzech, Cahors et dans les communes voisines.
        </p>

        <div class="mt-7 flex flex-wrap gap-3">
          <a
            href="tel:+33743528759"
            aria-label="Appeler Mon Terrain Parfait au 07 43 52 87 59"
            class="rounded-full bg-green-300 px-6 py-3 font-black text-green-950 transition hover:-translate-y-0.5 hover:bg-green-200"
          >
            07 43 52 87 59
          </a>

          <a
            href={whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-full border border-white/25 px-6 py-3 font-black transition hover:-translate-y-0.5 hover:bg-white hover:text-green-950"
          >
            WhatsApp
          </a>
        </div>

        <p class="mt-6 text-sm font-bold text-green-50/60">
          Devis gratuit et sans engagement
        </p>
      </div>

      <!-- Navigation -->
      <div class="lg:col-span-2">
        <p class="text-sm font-black uppercase tracking-[0.22em] text-green-300">
          Navigation
        </p>

        <nav
          class="mt-6 flex flex-col gap-3"
          aria-label="Navigation du pied de page"
        >
          <a
            href="/"
            class="text-green-50/75 transition hover:translate-x-1 hover:text-white"
          >
            Accueil
          </a>

          <a
            href="/services"
            class="text-green-50/75 transition hover:translate-x-1 hover:text-white"
          >
            Tous les services
          </a>

          <a
            href="/#realisations"
            class="text-green-50/75 transition hover:translate-x-1 hover:text-white"
          >
            Réalisations
          </a>

          <a
            href="/#secteur"
            class="text-green-50/75 transition hover:translate-x-1 hover:text-white"
          >
            Secteur
          </a>

          <a
            href="/#contact"
            class="text-green-50/75 transition hover:translate-x-1 hover:text-white"
          >
            Contact
          </a>
        </nav>
      </div>

      <!-- Services -->
      <div class="lg:col-span-3">
        <p class="text-sm font-black uppercase tracking-[0.22em] text-green-300">
          Nos services
        </p>

        <nav class="mt-6 flex flex-col gap-3" aria-label="Services">
          {
            services.map((service) => (
              <a
                href={service.href}
                class="text-green-50/75 transition hover:translate-x-1 hover:text-white"
              >
                {service.label}
              </a>
            ))
          }
        </nav>
      </div>

      <!-- Coordonnées -->
      <div class="lg:col-span-3">
        <p class="text-sm font-black uppercase tracking-[0.22em] text-green-300">
          Coordonnées
        </p>

        <div class="mt-6 space-y-5 text-green-50/75">
          <div>
            <p class="font-black text-white">Téléphone</p>

            <a
              href="tel:+33743528759"
              class="mt-1 block transition hover:text-white"
            >
              07 43 52 87 59
            </a>
          </div>

          <div>
            <p class="font-black text-white">E-mail</p>

            <a
              href="mailto:monterrainparfait@outlook.fr"
              class="mt-1 block break-all transition hover:text-white"
            >
              monterrainparfait@outlook.fr
            </a>
          </div>

          <div>
            <p class="font-black text-white">Secteur principal</p>

            <p class="mt-1">
              Luzech, Cahors et alentours
            </p>
          </div>

          <div>
            <p class="font-black text-white">Disponibilité</p>

            <p class="mt-1">
              Sur rendez-vous
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Zones d’intervention -->
    <div class="mt-14 border-t border-white/10 pt-10">
      <p class="text-sm font-black uppercase tracking-[0.22em] text-green-300">
        Zones d’intervention
      </p>

      <div class="mt-5 flex flex-wrap gap-3">
        {
          serviceAreas.map((area) => (
            <span class="rounded-full border border-white/15 bg-white/5 px-4 py-2 text-sm font-bold text-green-50/80">
              {area}
            </span>
          ))
        }
      </div>
    </div>

    <!-- Bas du footer -->
    <div
      class="mt-12 flex flex-col gap-5 border-t border-white/10 pt-8 text-sm text-green-50/60 md:flex-row md:items-center md:justify-between"
    >
      <p>
        © {currentYear} Mon Terrain Parfait. Tous droits réservés.
      </p>

      <div class="flex flex-wrap gap-x-6 gap-y-3">
        <a
          href="/mentions-legales"
          class="transition hover:text-white"
        >
          Mentions légales
        </a>

        <a
          href="/politique-de-confidentialite"
          class="transition hover:text-white"
        >
          Politique de confidentialité
        </a>
      </div>
    </div>
  </div>
</footer>