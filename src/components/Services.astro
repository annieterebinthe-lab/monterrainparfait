---
const services = [
  {
    title: "Débroussaillage",
    description:
      "Nettoyage des herbes hautes, ronces, broussailles et végétation dense pour retrouver un terrain propre et praticable.",
    icon: "🌿",
    link: "/services/debroussaillage",
  },
  {
    title: "Taille de haies",
    description:
      "Taille d’entretien, remise en forme et réduction de volume pour des haies propres, régulières et maîtrisées.",
    icon: "✂️",
    link: "/services/taille-haies",
  },
  {
    title: "Entretien de jardin",
    description:
      "Entretien ponctuel ou régulier de vos extérieurs pour conserver un jardin propre, agréable et soigné.",
    icon: "🌱",
    link: "/services/entretien-jardin",
  },
  {
    title: "Nettoyage de terrain",
    description:
      "Remise en état, dégagement des accès, ramassage et évacuation possible des déchets verts après intervention.",
    icon: "🧹",
    link: "/services/nettoyage-terrain",
  },
  {
    title: "Tonte de pelouse",
    description:
      "Tonte ponctuelle ou régulière, entretien des bordures et finitions pour une pelouse propre et uniforme.",
    icon: "🌾",
    link: "/services/tonte-pelouse",
  },
  {
    title: "Remise en état extérieure",
    description:
      "Intervention complète pour redonner un aspect propre, accessible et entretenu à un jardin laissé à l’abandon.",
    icon: "🏡",
    link: "/services/remise-en-etat",
  },
];

const whatsappLink =
  "https://wa.me/33743528759?text=Bonjour%2C%20je%20souhaite%20obtenir%20un%20premier%20avis%20pour%20mon%20terrain.";
---

<section id="services" class="bg-[#f7f5ee] py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="max-w-3xl">
      <p class="text-sm font-black uppercase tracking-[0.25em] text-green-700">
        Nos services
      </p>

      <h2
        class="mt-4 text-4xl font-black tracking-tight text-green-950 md:text-5xl"
      >
        Des prestations adaptées à chaque terrain
      </h2>

      <p class="mt-6 text-lg leading-8 text-slate-600">
        Nous intervenons pour remettre en état, entretenir et valoriser vos
        extérieurs à Luzech, Cahors et dans les communes voisines.
      </p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {
        services.map((service) => (
          <a
            href={service.link}
            class="group flex h-full flex-col rounded-[2rem] border border-green-950/10 bg-white p-7 shadow-sm transition duration-300 hover:-translate-y-2 hover:border-green-700/30 hover:shadow-xl"
          >
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-green-100 text-3xl">
              {service.icon}
            </div>

            <h3 class="mt-6 text-2xl font-black text-green-950">
              {service.title}
            </h3>

            <p class="mt-4 flex-1 leading-7 text-slate-600">
              {service.description}
            </p>

            <span
              class="mt-7 inline-flex items-center gap-2 font-black text-green-800 transition group-hover:gap-3"
            >
              Découvrir le service
              <span aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </div>

    <div
      class="mt-12 rounded-[2rem] bg-green-900 px-8 py-8 text-white md:flex md:items-center md:justify-between"
    >
      <div>
        <p class="text-sm font-black uppercase tracking-[0.22em] text-green-300">
          Besoin d’un chantier spécifique ?
        </p>

        <h3 class="mt-3 max-w-3xl text-3xl font-black">
          Envoyez-nous quelques photos pour obtenir un premier avis.
        </h3>
      </div>

      <a
        href={whatsappLink}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 inline-flex rounded-full bg-green-300 px-7 py-4 font-black text-green-950 transition hover:-translate-y-0.5 hover:bg-green-200 md:ml-8 md:mt-0"
      >
        Envoyer des photos
      </a>
    </div>
  </div>
</section>