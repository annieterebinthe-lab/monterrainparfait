---
const navItems = [
  { label: "Accueil", href: "/" },
  { label: "Services", href: "#services" },
  { label: "Réalisations", href: "#realisations" },
  { label: "Secteur", href: "#secteur" },
  { label: "Contact", href: "#contact" },
];
---

<header class="sticky top-0 z-50 border-b border-green-950/10 bg-[#fbfaf5]/95 backdrop-blur shadow-sm">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-6 py-5">

    <!-- Logo texte -->
    <a href="/" class="flex flex-col">
      <span class="text-4xl font-black tracking-tight text-green-950">
        Mon Terrain Parfait
      </span>

      <span class="mt-1 text-xs font-bold uppercase tracking-[0.35em] text-green-700">
        Débroussaillage • Entretien
      </span>
    </a>

    <!-- Navigation -->
    <nav class="hidden lg:flex items-center gap-8">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="font-semibold text-slate-700 transition hover:text-green-700"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- Boutons -->
    <div class="flex items-center gap-3">

      <a
        href="https://wa.me/33743528759"
        class="hidden md:inline-flex rounded-full border-2 border-green-700 px-6 py-3 font-bold text-green-800 transition hover:bg-green-700 hover:text-white"
      >
        WhatsApp
      </a>

      <a
        href="tel:+33743528759"
        class="rounded-full bg-green-800 px-6 py-3 font-bold text-white shadow-md transition hover:bg-green-700"
      >
        07 43 52 87 59
      </a>

    </div>

  </div>
</header>