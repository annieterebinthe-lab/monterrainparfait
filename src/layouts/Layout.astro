---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
}

const {
  title = "Mon Terrain Parfait | Espaces verts à Luzech",
  description =
    "Débroussaillage, taille de haies, entretien d'espaces verts et nettoyage de terrain à Luzech, Cahors et dans les communes voisines.",
  canonical,
  image = "/images/chantier-1-apres.jpg",
} = Astro.props;

const siteUrl = "https://www.monterrainparfait.fr";
const canonicalUrl = canonical
  ? new URL(canonical, siteUrl).toString()
  : new URL(Astro.url.pathname, siteUrl).toString();

const socialImage = new URL(image, siteUrl).toString();
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <title>{title}</title>

    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Mon Terrain Parfait" />
    <meta name="theme-color" content="#062f24" />

    <link rel="canonical" href={canonicalUrl} />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Mon Terrain Parfait" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        name: "Mon Terrain Parfait",
        url: siteUrl,
        telephone: "+33743528759",
        email: "monterrainparfait@outlook.fr",
        description,
        areaServed: [
          "Luzech",
          "Cahors",
          "Pradines",
          "Puy-l'Évêque",
          "Mercuès",
          "Douelle",
          "Caillac",
          "Espère",
        ],
        address: {
          "@type": "PostalAddress",
          addressLocality: "Luzech",
          addressRegion: "Occitanie",
          postalCode: "46140",
          addressCountry: "FR",
        },
      })}
    />
  </head>

  <body>
    <slot />
  </body>
</html>