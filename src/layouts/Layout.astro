---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
}

const {
  title = "Mon Terrain Parfait | Espaces verts à Luzech",
  description =
    "Débroussaillage, taille de haies, entretien de jardin et nettoyage de terrain à Luzech, Cahors et dans les communes voisines.",
  canonical,
  image = "/images/chantier-1-apres.jpg",
} = Astro.props;

const siteUrl = "https://monterrainparfait.fr";
const googleAnalyticsId = "G-X4K7L11767";

const canonicalUrl = canonical
  ? new URL(canonical, siteUrl).toString()
  : new URL(Astro.url.pathname, siteUrl).toString();

const socialImage = new URL(image, siteUrl).toString();
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <title>{title}</title>

    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Mon Terrain Parfait" />
    <meta name="theme-color" content="#062f24" />

    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/favicon-16x16.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/apple-touch-icon.png"
    />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Mon Terrain Parfait" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <!-- Données structurées -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        name: "Mon Terrain Parfait",
        url: siteUrl,
        telephone: "+33743528759",
        email: "monterrainparfait@outlook.fr",
        description,
        areaServed: [
          "Luzech",
          "Cahors",
          "Pradines",
          "Puy-l'Évêque",
          "Mercuès",
          "Douelle",
          "Caillac",
          "Espère",
        ],
        address: {
          "@type": "PostalAddress",
          addressLocality: "Luzech",
          addressRegion: "Occitanie",
          postalCode: "46140",
          addressCountry: "FR",
        },
      })}
    />
  </head>

  <body class="bg-[#f7f5ee] text-slate-800">
    <Header />

    <slot />

    <Footer />

    <!-- Bandeau de consentement Analytics -->
    <aside
      id="cookie-banner"
      class="fixed inset-x-4 bottom-4 z-[100] hidden rounded-[2rem] border border-white/10 bg-green-950 p-6 text-white shadow-2xl md:left-auto md:max-w-xl md:p-8"
      aria-labelledby="cookie-title"
      aria-describedby="cookie-description"
    >
      <p
        id="cookie-title"
        class="text-xl font-black"
      >
        Respect de votre vie privée
      </p>

      <p
        id="cookie-description"
        class="mt-3 leading-7 text-green-50/80"
      >
        Nous souhaitons utiliser Google Analytics pour mesurer anonymement
        l’audience et améliorer le site. Vous pouvez accepter ou refuser.
      </p>

      <p class="mt-3 text-sm text-green-100/70">
        Consultez notre
        <a
          href="/politique-de-confidentialite"
          class="font-bold text-green-300 underline underline-offset-4 hover:text-green-200"
        >
          politique de confidentialité
        </a>.
      </p>

      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <button
          id="accept-analytics"
          type="button"
          class="rounded-full bg-green-300 px-6 py-3 font-black text-green-950 transition hover:bg-green-200"
        >
          Accepter
        </button>

        <button
          id="refuse-analytics"
          type="button"
          class="rounded-full border border-white/30 px-6 py-3 font-black text-white transition hover:bg-white/10"
        >
          Refuser
        </button>
      </div>
    </aside>

    <script
      is:inline
      define:vars={{ googleAnalyticsId }}
    >
      const consentKey = "monterrainparfait-analytics-consent";
      const cookieBanner = document.getElementById("cookie-banner");
      const acceptButton = document.getElementById("accept-analytics");
      const refuseButton = document.getElementById("refuse-analytics");

      let analyticsLoaded = false;

      function loadGoogleAnalytics() {
        if (analyticsLoaded) {
          return;
        }

        analyticsLoaded = true;

        window.dataLayer = window.dataLayer || [];

        window.gtag = function () {
          window.dataLayer.push(arguments);
        };

        window.gtag("js", new Date());
        window.gtag("config", googleAnalyticsId, {
          anonymize_ip: true,
        });

        const analyticsScript = document.createElement("script");
        analyticsScript.async = true;
        analyticsScript.src =
          `https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`;

        document.head.appendChild(analyticsScript);
      }

      function hideCookieBanner() {
        cookieBanner?.classList.add("hidden");
      }

      function showCookieBanner() {
        cookieBanner?.classList.remove("hidden");
      }

      const savedConsent = localStorage.getItem(consentKey);

      if (savedConsent === "accepted") {
        loadGoogleAnalytics();
      } else if (savedConsent !== "refused") {
        showCookieBanner();
      }

      acceptButton?.addEventListener("click", () => {
        localStorage.setItem(consentKey, "accepted");
        loadGoogleAnalytics();
        hideCookieBanner();
      });

      refuseButton?.addEventListener("click", () => {
        localStorage.setItem(consentKey, "refused");
        hideCookieBanner();
      });
    </script>
  </body>
</html>